{
	"name": "@0xintuition/workers",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"license": "MIT",
	"scripts": {
		"up": "bun run dev:kg:parse",
		"build": "true",
		"dev:kg:parse": "bun with-env bun --watch src/index.ts kg-parse-worker",
		"dev:kg:classification": "bun with-env bun --watch src/index.ts kg-classification-worker",
		"dev:kg:enrichment": "bun with-env bun --watch src/index.ts kg-enrichment-worker",
		"start:kg:parse": "bun with-env bun src/index.ts kg-parse-worker",
		"start:kg:classification": "bun with-env bun src/index.ts kg-classification-worker",
		"start:kg:enrichment": "bun with-env bun src/index.ts kg-enrichment-worker",
		"command": "bun with-env bun src/index.ts",
		"test": "bun test src/shared src/core src/kg",
		"typecheck": "tsc --noEmit",
		"with-env": "dotenv -e ../../.env --",
		"ci": "biome check",
		"lint": "biome lint",
		"format": "biome format",
		"check": "biome check",
		"check:write": "biome check --write",
		"clean": "git clean -xdf .cache .turbo dist node_modules"
	},
	"dependencies": {
		"@0xintuition/atom-classification": "workspace:*",
		"@0xintuition/atom-enrichment": "workspace:*",
		"@0xintuition/atom-parser": "workspace:*",
		"@0xintuition/atom-services": "workspace:*",
		"@0xintuition/database-kg": "workspace:*",
		"drizzle-orm": "0.45.1",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@0xintuition/tsconfig": "workspace:*",
		"@types/bun": "^1.3.3",
		"dotenv-cli": "^10.0.0",
		"typescript": "catalog:"
	}
}
