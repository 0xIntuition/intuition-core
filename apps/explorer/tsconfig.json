{
	"extends": "@0xintuition/tsconfig/base.json",
	"compilerOptions": {
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"types": ["vite/client"],
		"strictNullChecks": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src", "vite.config.ts"],
	"exclude": ["node_modules", ".output", ".nitro", "dist"]
}
