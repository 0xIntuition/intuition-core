# ─────────────────────────────────────────────────────────────────────────────
# Intuition Core — environment
#
#   cp example.env .env
#
# The MINIMAL tier (datastores + indexer + workers + api) needs ZERO paid
# third-party accounts. Everything below the "optional" line is opt-in and
# degrades gracefully when unset.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Datastores ───────────────────────────────────────────────────────────────
# These defaults match docker-compose.datastores.yml — they work out of the box.

# PostgreSQL knowledge graph (atoms, triples, accounts, predicates)
DATABASE_KG_URL=postgresql://intuition:intuition@localhost:5432/intuition_kg

# TimescaleDB time-series (event store, markets, positions, leaderboards)
DATABASE_TIMESCALE_URL=postgresql://intuition:intuition@localhost:5433/intuition_timescale

# Redis (indexer leader election)
REDIS_URL=redis://localhost:6379

# ── Query API ────────────────────────────────────────────────────────────────
API_PORT=3000
# Comma-separated allowed CORS origins (empty = allow all in dev)
API_ALLOWED_ORIGINS=
# Endpoint gating: open | public-read | gated.
#   public-read (default): reads open, writes need an API key
#   gated: everything needs a key · open: no keys (local dev, unattributed writes)
# Mint keys: bun --filter @0xintuition/api run keys:create -- --name me --account 0xYourWallet
API_AUTH=public-read

# ── Chain / indexer ──────────────────────────────────────────────────────────
# Point the indexer at the Intuition chain (or any EVM MultiVault deployment).
# No defaults are baked into code — set these to index.
# Start with: docker compose --profile indexing up
INTUITION_RPC_URL=
CHAIN_ID=
MULTIVAULT_CONTRACT_ADDRESS=
MULTIVAULT_START_BLOCK=
# Optional: stop at this block instead of syncing to head. Set a small window
# (e.g. START_BLOCK + 500) for a cheap end-to-end test run.
MULTIVAULT_END_BLOCK=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — none of the below are required for the minimal tier.
# ─────────────────────────────────────────────────────────────────────────────

# Embeddings / semantic search (+ Search tier). Off by default.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Enrichment provider plugins (+ Rich enrichment). Each is optional; the matching
# plugin degrades gracefully when its key is absent.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
GITHUB_TOKEN=
ETHERSCAN_API_KEY=
BRANDFETCH_API_KEY=
