# atom-services — stateless classify/enrich HTTP API.
#   POST /v1/classify · /v1/enrich · /v1/process · /v1/process/batch
# Build context: repo root (Bun workspace).

FROM oven/bun:1.3.11-alpine

ARG VERSION=dev
ARG VCS_REF=unknown
ARG CREATED=unknown
LABEL org.opencontainers.image.title="Intuition Core Atom Services" \
      org.opencontainers.image.description="Stateless classify and enrich HTTP API for Intuition Core atoms" \
      org.opencontainers.image.source="https://github.com/0xIntuition/intuition-core" \
      org.opencontainers.image.url="https://github.com/0xIntuition/intuition-core" \
      org.opencontainers.image.documentation="https://github.com/0xIntuition/intuition-core/tree/main/docs" \
      org.opencontainers.image.licenses="MIT" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.revision="${VCS_REF}" \
      org.opencontainers.image.created="${CREATED}"

RUN apk add --no-cache curl

WORKDIR /repo
COPY . .
RUN bun install --frozen-lockfile --production

ENV NODE_ENV=production
ENV ATOM_SERVICES_PORT=4010
EXPOSE 4010

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:4010/health || exit 1

WORKDIR /repo/services/atom-services
USER bun
CMD ["bun", "src/index.ts"]
