{
	"name": "@0xintuition/atom-classification-example-plugin",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"license": "MIT",
	"scripts": {
		"build": "tsc",
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"dev": "tsc --watch",
		"typecheck": "tsc --noEmit",
		"ci": "biome check",
		"lint": "biome lint",
		"format": "biome format",
		"check": "biome check",
		"lint:write": "biome lint --write",
		"format:write": "biome format --write",
		"check:write": "biome check --write",
		"check:unsafe:write": "biome check --write --unsafe"
	},
	"dependencies": {
		"@0xintuition/atom-classification": "workspace:*"
	},
	"devDependencies": {
		"@0xintuition/tsconfig": "workspace:*",
		"typescript": "catalog:"
	}
}
